{
  "manifest_version": 3,
  "name": "pxlpeep",
  "version": "1.0.0",
  "description": "Power-user image inspector: palette mapping, white balance, rulers, ROI, EXIF, channel selection.",
  "icons": {
    "16":  "loupe.iconset/icon_16x16.png",
    "32":  "loupe.iconset/icon_32x32.png",
    "48":  "loupe.iconset/icon_64x64.png",
    "128": "loupe.iconset/icon_128x128.png"
  },
  "background": {
    "service_worker": "background/worker.js",
    "scripts": ["background/worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["content/takeover.js"]
    }
  ],
  "permissions": ["contextMenus"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    { "resources": ["content/main.js"], "matches": ["<all_urls>"] }
  ]
}
